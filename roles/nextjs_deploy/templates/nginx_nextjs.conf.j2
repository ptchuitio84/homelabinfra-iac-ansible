# Generated by Ansible — do not edit manually.

server {
    listen 80;
    server_name {{ nextjs_domain }};
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name {{ nextjs_domain }};

    ssl_certificate     {{ nextjs_ssl_cert }};
    ssl_certificate_key {{ nextjs_ssl_key }};
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;
    ssl_session_cache   shared:SSL:10m;
    ssl_session_timeout 10m;

    access_log /var/log/nginx/{{ nextjs_app_name }}_access.log;
    error_log  /var/log/nginx/{{ nextjs_app_name }}_error.log;

    location / {
        proxy_pass         http://localhost:{{ nextjs_port }};
        proxy_http_version 1.1;
        proxy_set_header   Upgrade $http_upgrade;
        proxy_set_header   Connection 'upgrade';
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto https;
        proxy_cache_bypass $http_upgrade;
    }
}
