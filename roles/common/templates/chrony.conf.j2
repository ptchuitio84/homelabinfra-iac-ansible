# =============================================================================
# chrony.conf — NTP Client Configuration (generated by Ansible)
# =============================================================================
# This file is managed by Ansible. Do not edit manually — changes will be
# overwritten the next time the "common" role runs.
#
# chrony is the NTP client used on OL10/RHEL to keep the system clock
# synchronized. Accurate time is critical for:
#   - TLS certificate validation (certificates have exact validity windows)
#   - Kerberos / Active Directory authentication (requires clocks within 5 min)
#   - Log correlation across hosts (timestamps must align)
# =============================================================================

# NTP servers — generated from the ntp_servers list in defaults/main.yml.
# "iburst" sends a burst of packets on startup to sync faster.
{% for server in ntp_servers %}
server {{ server }} iburst
{% endfor %}

# File where chrony stores clock drift measurements between reboots.
driftfile /var/lib/chrony/drift

# Allow the clock to step (jump) by up to 1 second during the first 3 updates.
# After that, only slew (gradual adjustments) are allowed.
# This handles large initial time offsets without disrupting running processes.
makestep 1.0 3

# Keep the hardware clock (RTC) in sync with the system clock.
rtcsync

# Directory for chrony log files.
logdir /var/log/chrony
