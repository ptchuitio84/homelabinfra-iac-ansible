# =============================================================================
# up.conf — UnPoller Configuration
# =============================================================================
# Generated by Ansible — do not edit manually.
# Source: roles/unpoller/templates/up.conf.j2
# =============================================================================

[poller]
  debug = false
  quiet = false

[prometheus]
  disable   = false
  http_listen = "0.0.0.0:{{ unpoller_port }}"
  report_errors = true

[influxdb]
  disable = true

[unifi]
  dynamic = false

  [[unifi.controller]]
    url            = "{{ unifi_controller_url }}"
    user           = "{{ vault_unifi_user }}"
    pass           = "{{ vault_unifi_password }}"
    sites          = ["{{ unifi_site }}"]
    save_sites     = true
    save_ids       = true
    save_events    = true
    save_alarms    = true
    save_anomalies = true
    save_dpi       = true
    verify_ssl     = {{ unifi_controller_verify_ssl | lower }}
