# =============================================================================
# Generated by Ansible — do not edit manually.
# Source: roles/prometheus/templates/rules/network.rules.yml.j2
# =============================================================================

groups:
  - name: network
    rules:

      - alert: SwitchDown
        expr: up{job="snmp"} == 0
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: "Switch {{ "{{" }} $labels.instance {{ "}}" }} is unreachable"
          description: >
            SNMP scrape of {{ "{{" }} $labels.instance {{ "}}" }} has been failing for 2 minutes.
            Check switch power, uplink, and management VLAN connectivity.
