# =============================================================================
# node.rules.yml — Linux Host Alert Rules
# =============================================================================
# Generated by Ansible — do not edit manually.
# Source: roles/prometheus/templates/rules/node.rules.yml.j2
# =============================================================================

groups:
  - name: node
    rules:

      - alert: NodeDown
        expr: up{job="node_exporter"} == 0
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: "Node {{ "{{" }} $labels.instance {{ "}}" }} is down"
          description: "node_exporter on {{ "{{" }} $labels.instance {{ "}}" }} has been unreachable for 2 minutes."

      - alert: DiskSpaceWarning
        expr: >
          (
            node_filesystem_avail_bytes{fstype!~"tmpfs|overlay|devtmpfs"}
            / node_filesystem_size_bytes{fstype!~"tmpfs|overlay|devtmpfs"}
          ) * 100 < 20
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "Disk space low on {{ "{{" }} $labels.instance {{ "}}" }}"
          description: "Filesystem {{ "{{" }} $labels.mountpoint {{ "}}" }} on {{ "{{" }} $labels.instance {{ "}}" }} has {{ "{{" }} $value {{ "}}" }}% free."

      - alert: DiskSpaceCritical
        expr: >
          (
            node_filesystem_avail_bytes{fstype!~"tmpfs|overlay|devtmpfs"}
            / node_filesystem_size_bytes{fstype!~"tmpfs|overlay|devtmpfs"}
          ) * 100 < 10
        for: 5m
        labels:
          severity: critical
        annotations:
          summary: "Disk space critical on {{ "{{" }} $labels.instance {{ "}}" }}"
          description: "Filesystem {{ "{{" }} $labels.mountpoint {{ "}}" }} on {{ "{{" }} $labels.instance {{ "}}" }} has {{ "{{" }} $value {{ "}}" }}% free."

      - alert: HighMemoryUsage
        expr: >
          (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100 < 10
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "High memory usage on {{ "{{" }} $labels.instance {{ "}}" }}"
          description: "Available memory on {{ "{{" }} $labels.instance {{ "}}" }} is below 10% ({{ "{{" }} $value {{ "}}" }}% available)."
