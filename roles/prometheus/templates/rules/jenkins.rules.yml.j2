# =============================================================================
# jenkins.rules.yml — Jenkins Alert Rules
# =============================================================================
# Generated by Ansible — do not edit manually.
# Source: roles/prometheus/templates/rules/jenkins.rules.yml.j2
#
# Metric: default_jenkins_builds_last_build_result_ordinal
#   0 = SUCCESS, 1 = UNSTABLE, 2 = FAILURE, 3 = NOT_BUILT, 4 = ABORTED
# =============================================================================

groups:
  - name: jenkins
    rules:

      - alert: JenkinsDown
        expr: up{job="jenkins"} == 0
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: "Jenkins is unreachable"
          description: "Prometheus cannot scrape the Jenkins metrics endpoint. Jenkins may be down or the Prometheus plugin is broken."

      - alert: JenkinsBuildFailed
        expr: default_jenkins_builds_last_build_result_ordinal{jenkins_job!~".*test.*"} >= 2
        for: 0m
        labels:
          severity: warning
        annotations:
          summary: "Jenkins build failed: {{ "{{" }} $labels.jenkins_job {{ "}}" }}"
          description: >
            Pipeline {{ "{{" }} $labels.jenkins_job {{ "}}" }} last build result ordinal is {{ "{{" }} $value {{ "}}" }}
            (2=FAILURE, 3=NOT_BUILT, 4=ABORTED).
