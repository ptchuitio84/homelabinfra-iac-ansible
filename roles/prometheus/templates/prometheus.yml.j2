# =============================================================================
# prometheus.yml — Prometheus Scrape Configuration
# =============================================================================
# Generated by Ansible — do not edit manually.
# Source: roles/prometheus/templates/prometheus.yml.j2
# =============================================================================

global:
  scrape_interval:     {{ prometheus_scrape_interval }}
  evaluation_interval: {{ prometheus_evaluation_interval }}

# =============================================================================
# SCRAPE CONFIGS
# Each job defines a set of targets Prometheus polls for metrics.
# =============================================================================

scrape_configs:

  # ── Prometheus self-monitoring ─────────────────────────────────────────────
  - job_name: "prometheus"
    static_configs:
      - targets: ["localhost:{{ prometheus_port }}"]

  # ── Linux VMs (node_exporter) ──────────────────────────────────────────────
  # node_exporter exposes CPU, RAM, disk, network, and system metrics.
  # Must be installed on each target VM (handled by the node_exporter role).
  - job_name: "node_exporter"
    static_configs:
      - targets:
{% for target in prometheus_node_targets %}
          - "{{ target }}"
{% endfor %}

  # ── Jenkins ────────────────────────────────────────────────────────────────
  # Jenkins exposes build metrics via the Prometheus Metrics plugin.
  # Endpoint requires auth — credentials stored in vault.
  - job_name: "jenkins"
    metrics_path: /prometheus
    basic_auth:
      username: "{{ vault_jenkins_prometheus_user }}"
      password: "{{ vault_jenkins_prometheus_token }}"
    static_configs:
      - targets: ["hmvlapjkn001.nnt.com:{{ jenkins_metrics_port }}"]

  # ── VMware vCenter (vmware_exporter direct mode) ──────────────────────────
  # vmware_exporter on mon002 connects to vCenter via config.yml and exposes
  # ESXi/VM metrics. Direct scrape — uses default config section.
  - job_name: "vmware"
    static_configs:
      - targets: ["{{ prometheus_vmware_exporter_host }}:{{ vmware_exporter_port }}"]

  # ── Network devices (snmp_exporter) ───────────────────────────────────────
  # snmp_exporter polls switches via SNMP and exposes interface stats,
  # error counters, and device uptime as Prometheus metrics.
  - job_name: "snmp"
    static_configs:
      - targets:
{% for target in prometheus_snmp_targets %}
          - "{{ target }}"
{% endfor %}
    metrics_path: /snmp
    params:
      module: [if_mib]
      auth: [public_v2]
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: "localhost:{{ snmp_exporter_port }}"

  # ── UniFi APs (unpoller) ──────────────────────────────────────────────────
  # unpoller on mon003 polls the UniFi Network Application and exposes
  # AP, client, and site metrics for the 3x AP Pro 6/7 units.
  - job_name: "unifi"
    static_configs:
      - targets: ["{{ prometheus_unpoller_host }}:{{ unpoller_port }}"]

  # ── Meraki MX64 (meraki_exporter) ─────────────────────────────────────────
  # meraki_exporter on mon003 polls the Meraki Dashboard API and exposes
  # MX appliance uplink status, device health, and client counts.
  - job_name: "meraki"
    static_configs:
      - targets: ["{{ prometheus_meraki_exporter_host }}:{{ meraki_exporter_port }}"]
