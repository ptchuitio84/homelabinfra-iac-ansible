# =============================================================================
# prometheus.yml — Prometheus Scrape Configuration
# =============================================================================
# Generated by Ansible — do not edit manually.
# Source: roles/prometheus/templates/prometheus.yml.j2
# =============================================================================

global:
  scrape_interval:     {{ prometheus_scrape_interval }}
  evaluation_interval: {{ prometheus_evaluation_interval }}

# =============================================================================
# SCRAPE CONFIGS
# Each job defines a set of targets Prometheus polls for metrics.
# =============================================================================

scrape_configs:

  # ── Prometheus self-monitoring ─────────────────────────────────────────────
  - job_name: "prometheus"
    static_configs:
      - targets: ["localhost:{{ prometheus_port }}"]

  # ── Linux VMs (node_exporter) ──────────────────────────────────────────────
  # node_exporter exposes CPU, RAM, disk, network, and system metrics.
  # Must be installed on each target VM (handled by the node_exporter role).
  - job_name: "node_exporter"
    static_configs:
      - targets:
{% for target in prometheus_node_targets %}
          - "{{ target }}"
{% endfor %}

  # ── Jenkins ────────────────────────────────────────────────────────────────
  # Jenkins exposes build metrics via the Prometheus Metrics plugin.
  # Install plugin: Manage Jenkins → Plugins → "Prometheus metrics"
  - job_name: "jenkins"
    metrics_path: /prometheus
    static_configs:
      - targets: ["hmvlapjkn001.nnt.com:{{ jenkins_metrics_port }}"]

  # ── VMware ESXi (Telegraf vSphere input) ──────────────────────────────────
  # Telegraf on mon002 connects to vCenter API via inputs.vsphere and exposes
  # host, VM, datastore, and cluster metrics via outputs.prometheus_client.
  # Direct scrape — no proxy mode, no relabeling needed.
  # Replaces pryorda/vmware_exporter (abandoned, broken on vCenter 7.x).
  - job_name: "vmware"
    static_configs:
      - targets: ["hmvlapmon002.nnt.com:{{ telegraf_prometheus_port }}"]

  # ── Network devices (snmp_exporter) ───────────────────────────────────────
  # snmp_exporter polls switches via SNMP and exposes interface stats,
  # error counters, and device uptime as Prometheus metrics.
  - job_name: "snmp"
    static_configs:
      - targets:
{% for target in prometheus_snmp_targets %}
          - "{{ target }}"
{% endfor %}
    metrics_path: /snmp
    params:
      module: [if_mib]
      auth: [public_v2]
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: "localhost:{{ snmp_exporter_port }}"
