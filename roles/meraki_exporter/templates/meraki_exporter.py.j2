#!/{{ meraki_exporter_venv }}/bin/python3
# =============================================================================
# meraki_exporter.py — Prometheus exporter for Meraki Dashboard API
# =============================================================================
# Generated by Ansible — do not edit manually.
# Source: roles/meraki_exporter/templates/meraki_exporter.py.j2
#
# DEVICE: MX64 appliance
# METRICS:
#   meraki_device_up                — online status (1=online, 0=offline)
#   meraki_appliance_uplink_status  — WAN uplink active (1=active, 0=not)
#   meraki_network_client_count     — clients seen in last 5 minutes
# =============================================================================

import time
import logging
import meraki
from prometheus_client import start_http_server, Gauge

logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s %(levelname)s %(message)s'
)
log = logging.getLogger(__name__)

API_KEY       = "{{ vault_meraki_api_key }}"
ORG_ID        = "{{ meraki_org_id }}"
POLL_INTERVAL = {{ meraki_exporter_poll_interval }}
PORT          = {{ meraki_exporter_port }}

# ---------------------------------------------------------------------------
# Metric definitions
# ---------------------------------------------------------------------------

device_up = Gauge(
    'meraki_device_up',
    'Meraki device online status (1=online, 0=offline/alerting/dormant)',
    ['serial', 'name', 'model', 'network_id']
)

uplink_status = Gauge(
    'meraki_appliance_uplink_status',
    'MX appliance uplink active status (1=active, 0=not active)',
    ['serial', 'network_id', 'interface', 'provider', 'ip']
)

client_count = Gauge(
    'meraki_network_client_count',
    'Number of clients seen on the network in the last 5 minutes',
    ['network_id', 'network_name']
)

# ---------------------------------------------------------------------------
# Collection
# ---------------------------------------------------------------------------

def collect(dashboard):
    # -- Device status -------------------------------------------------------
    try:
        statuses = dashboard.organizations.getOrganizationDevicesStatuses(
            ORG_ID, total_pages='all'
        )
        for d in statuses:
            if d.get('productType') != 'appliance':
                continue
            up = 1 if d.get('status') == 'online' else 0
            device_up.labels(
                serial=d.get('serial', ''),
                name=d.get('name', d.get('serial', '')),
                model=d.get('model', ''),
                network_id=d.get('networkId', '')
            ).set(up)
    except Exception as e:
        log.error(f"Device status collection failed: {e}")

    # -- Uplink status -------------------------------------------------------
    try:
        uplinks = dashboard.appliance.getOrganizationApplianceUplinkStatuses(
            ORG_ID, total_pages='all'
        )
        for device in uplinks:
            serial     = device.get('serial', '')
            network_id = device.get('networkId', '')
            for ul in device.get('uplinks', []):
                active = 1 if ul.get('status') == 'active' else 0
                uplink_status.labels(
                    serial=serial,
                    network_id=network_id,
                    interface=ul.get('interface', ''),
                    provider=ul.get('provider', 'unknown'),
                    ip=ul.get('ip', '')
                ).set(active)
    except Exception as e:
        log.error(f"Uplink status collection failed: {e}")

    # -- Client count --------------------------------------------------------
    try:
        networks = dashboard.organizations.getOrganizationNetworks(
            ORG_ID, total_pages='all'
        )
        for net in networks:
            try:
                clients = dashboard.networks.getNetworkClients(
                    net['id'], timespan=300, total_pages='all'
                )
                client_count.labels(
                    network_id=net['id'],
                    network_name=net.get('name', net['id'])
                ).set(len(clients))
            except Exception as e:
                log.warning(f"Client count failed for network {net['id']}: {e}")
    except Exception as e:
        log.error(f"Network list collection failed: {e}")


def main():
    dashboard = meraki.DashboardAPI(
        API_KEY,
        suppress_logging=True,
        maximum_retries=3,
        wait_on_rate_limit=True
    )

    start_http_server(PORT)
    log.info(f"Meraki exporter started — listening on :{PORT}, polling every {POLL_INTERVAL}s")

    while True:
        log.info("Collecting metrics from Meraki Dashboard API...")
        collect(dashboard)
        log.info(f"Collection complete. Next poll in {POLL_INTERVAL}s.")
        time.sleep(POLL_INTERVAL)


if __name__ == '__main__':
    main()
