# =============================================================================
# /etc/grafana/grafana.ini — managed by Ansible (roles/grafana)
# =============================================================================

[server]
http_port = {{ grafana_port }}
domain = {{ ansible_host }}
root_url = http://{{ grafana_fqdn | default(inventory_hostname) }}:{{ grafana_port }}/

[paths]
data = {{ grafana_data_dir }}
logs = {{ grafana_log_dir }}
plugins = {{ grafana_plugins_dir }}
provisioning = {{ grafana_config_dir }}/provisioning

[security]
admin_user = {{ grafana_admin_user }}
admin_password = {{ grafana_admin_password }}

[users]
allow_sign_up = false

[auth.anonymous]
enabled = false

[log]
mode = file
level = info

[analytics]
reporting_enabled = false
check_for_updates = false
{% if grafana_oidc_enabled %}

[auth.generic_oauth]
enabled = true
name = Keycloak
allow_sign_up = true
client_id = {{ grafana_oidc_client_id }}
client_secret = {{ grafana_oidc_client_secret }}
scopes = openid email profile
auth_url = {{ grafana_oidc_issuer_base }}/protocol/openid-connect/auth
token_url = {{ grafana_oidc_issuer_base }}/protocol/openid-connect/token
api_url = {{ grafana_oidc_issuer_base }}/protocol/openid-connect/userinfo
signout_redirect_url = {{ grafana_oidc_issuer_base }}/protocol/openid-connect/logout
role_attribute_path = contains(roles[*], 'Admin') && 'Admin' || contains(roles[*], 'Editor') && 'Editor' || 'Viewer'
{% endif %}
