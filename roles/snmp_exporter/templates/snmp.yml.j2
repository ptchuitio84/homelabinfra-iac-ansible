# =============================================================================
# roles/snmp_exporter/templates/snmp.yml.j2 — SNMP Exporter Module Config
# =============================================================================
# Managed by Ansible — do not edit manually.
#
# Config format: snmp_exporter >= 0.26.0 (auth-split format)
# In this format, auths are top-level and NOT referenced inside modules.
# Auth is selected at scrape time via URL param: ?auth=public_v2
# See: https://github.com/prometheus/snmp_exporter/blob/main/auth-split-migration.md
#
# Modules:
#   if_mib       — interface traffic, status, errors (RFC 2863 + HC counters)
#   cisco_extras — CPU, memory (Cisco enterprise OIDs)
# =============================================================================

auths:
  public_v2:
    community: {{ snmp_exporter_community }}
    version: 2

modules:

  # ---------------------------------------------------------------------------
  # if_mib — Interface MIB (RFC 2863)
  # ---------------------------------------------------------------------------
  if_mib:
    walk:
      - 1.3.6.1.2.1.1        # system group — sysDescr, sysUpTime, sysName
      - 1.3.6.1.2.1.2.2      # ifTable
      - 1.3.6.1.2.1.31.1.1   # ifXTable — ifName, ifAlias, HC counters

    get:
      - 1.3.6.1.2.1.1.3.0    # sysUpTime

    metrics:

      # --- System ---
      - name: sysUpTime
        oid: 1.3.6.1.2.1.1.3.0
        type: gauge
        help: "The time (in hundredths of a second) since the network management portion of the system was last re-initialized."

      # --- ifTable ---
      - name: ifDescr
        oid: 1.3.6.1.2.1.2.2.1.2
        type: DisplayString
        help: "A textual string containing information about the interface."
        indexes:
          - labelname: ifIndex
            type: gauge

      - name: ifType
        oid: 1.3.6.1.2.1.2.2.1.3
        type: gauge
        help: "The type of interface."
        indexes:
          - labelname: ifIndex
            type: gauge

      - name: ifSpeed
        oid: 1.3.6.1.2.1.2.2.1.5
        type: gauge
        help: "An estimate of the interface's current bandwidth in bits per second."
        indexes:
          - labelname: ifIndex
            type: gauge

      - name: ifAdminStatus
        oid: 1.3.6.1.2.1.2.2.1.7
        type: gauge
        help: "The desired state of the interface (1=up, 2=down, 3=testing)."
        indexes:
          - labelname: ifIndex
            type: gauge
        enum_values:
          1: up
          2: down
          3: testing

      - name: ifOperStatus
        oid: 1.3.6.1.2.1.2.2.1.8
        type: gauge
        help: "The current operational state of the interface."
        indexes:
          - labelname: ifIndex
            type: gauge
        enum_values:
          1: up
          2: down
          3: testing
          4: unknown
          5: dormant
          6: notPresent
          7: lowerLayerDown

      - name: ifInErrors
        oid: 1.3.6.1.2.1.2.2.1.14
        type: counter
        help: "The number of inbound packets that contained errors."
        indexes:
          - labelname: ifIndex
            type: gauge

      - name: ifOutErrors
        oid: 1.3.6.1.2.1.2.2.1.20
        type: counter
        help: "The number of outbound packets that could not be transmitted because of errors."
        indexes:
          - labelname: ifIndex
            type: gauge

      # --- ifXTable — 64-bit HC counters ---
      - name: ifName
        oid: 1.3.6.1.2.1.31.1.1.1.1
        type: DisplayString
        help: "The textual name of the interface (e.g. GigabitEthernet0/1)."
        indexes:
          - labelname: ifIndex
            type: gauge

      - name: ifHCInOctets
        oid: 1.3.6.1.2.1.31.1.1.1.6
        type: counter
        help: "Total octets received on the interface. 64-bit counter."
        indexes:
          - labelname: ifIndex
            type: gauge

      - name: ifHCInUcastPkts
        oid: 1.3.6.1.2.1.31.1.1.1.7
        type: counter
        help: "Unicast packets received. 64-bit counter."
        indexes:
          - labelname: ifIndex
            type: gauge

      - name: ifHCOutOctets
        oid: 1.3.6.1.2.1.31.1.1.1.10
        type: counter
        help: "Total octets transmitted out of the interface. 64-bit counter."
        indexes:
          - labelname: ifIndex
            type: gauge

      - name: ifHCOutUcastPkts
        oid: 1.3.6.1.2.1.31.1.1.1.11
        type: counter
        help: "Unicast packets transmitted. 64-bit counter."
        indexes:
          - labelname: ifIndex
            type: gauge

      - name: ifHighSpeed
        oid: 1.3.6.1.2.1.31.1.1.1.15
        type: gauge
        help: "Interface bandwidth in units of 1,000,000 bits per second."
        indexes:
          - labelname: ifIndex
            type: gauge

      - name: ifAlias
        oid: 1.3.6.1.2.1.31.1.1.1.18
        type: DisplayString
        help: "Alias name for the interface as specified by a network manager."
        indexes:
          - labelname: ifIndex
            type: gauge

  # ---------------------------------------------------------------------------
  # cisco_extras — Cisco enterprise MIBs (CPU, memory)
  # ---------------------------------------------------------------------------
  cisco_extras:
    walk:
      - 1.3.6.1.4.1.9.9.109.1.1.1   # cpmCPUTotalTable
      - 1.3.6.1.4.1.9.9.48.1.1       # ciscoMemoryPoolTable

    metrics:

      - name: cpmCPUTotal5sec
        oid: 1.3.6.1.4.1.9.9.109.1.1.1.1.3
        type: gauge
        help: "Overall CPU busy percentage in the last 5 second period."
        indexes:
          - labelname: cpmCPUTotalIndex
            type: gauge

      - name: cpmCPUTotal1min
        oid: 1.3.6.1.4.1.9.9.109.1.1.1.1.4
        type: gauge
        help: "Overall CPU busy percentage in the last 1 minute period."
        indexes:
          - labelname: cpmCPUTotalIndex
            type: gauge

      - name: cpmCPUTotal5min
        oid: 1.3.6.1.4.1.9.9.109.1.1.1.1.5
        type: gauge
        help: "Overall CPU busy percentage in the last 5 minute period."
        indexes:
          - labelname: cpmCPUTotalIndex
            type: gauge

      - name: ciscoMemoryPoolUsed
        oid: 1.3.6.1.4.1.9.9.48.1.1.1.5
        type: gauge
        help: "Bytes from the memory pool currently in use."
        indexes:
          - labelname: ciscoMemoryPoolType
            type: gauge

      - name: ciscoMemoryPoolFree
        oid: 1.3.6.1.4.1.9.9.48.1.1.1.6
        type: gauge
        help: "Bytes from the memory pool currently unused."
        indexes:
          - labelname: ciscoMemoryPoolType
            type: gauge

      - name: ciscoMemoryPoolName
        oid: 1.3.6.1.4.1.9.9.48.1.1.1.2
        type: DisplayString
        help: "Name of the memory pool (e.g. Processor, I/O)."
        indexes:
          - labelname: ciscoMemoryPoolType
            type: gauge
