# =============================================================================
# alertmanager.yml — Alertmanager Configuration
# =============================================================================
# Generated by Ansible — do not edit manually.
# Source: roles/alertmanager/templates/alertmanager.yml.j2
#
# SMTP relay: webmail.nanonetech.com:25 (Exchange receive connector, no auth)
# All alerts route to infra-ops@nanonetech.com
# =============================================================================

global:
  smtp_smarthost:   '{{ alertmanager_smtp_host }}:{{ alertmanager_smtp_port }}'
  smtp_from:        '{{ alertmanager_smtp_from }}'
  smtp_require_tls: {{ alertmanager_smtp_tls | lower }}

route:
  group_by:         ['alertname', 'instance']
  group_wait:       {{ alertmanager_group_wait }}
  group_interval:   {{ alertmanager_group_interval }}
  repeat_interval:  {{ alertmanager_repeat_interval }}
  receiver:         email

receivers:
  - name: email
    email_configs:
      - to:            '{{ alertmanager_alert_email }}'
        send_resolved: true

# Suppress node-level alerts (disk, memory) when the node itself is down.
# No point alerting on the symptom when the root cause alert is already firing.
inhibit_rules:
  - source_matchers:
      - alertname = NodeDown
    target_matchers:
      - alertname =~ "DiskSpace.*|HighMemory.*"
    equal: ['instance']
